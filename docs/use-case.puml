@startuml
title Money Manager - Use Cases
left to right direction
skinparam packageStyle rectangle

actor User as user

rectangle "Money Manager" {
  usecase "Register" as UC_Register
  usecase "Login" as UC_Login
  usecase "Logout / Exit" as UC_Exit

  usecase "View Dashboard" as UC_Dashboard
  usecase "Set Monthly Income" as UC_SetIncome
  usecase "Auto-Apply Monthly Income\n(create tx + set monthly cap)" as UC_AutoApply

  usecase "Add Transaction" as UC_AddTx
  usecase "Edit Transaction" as UC_EditTx
  usecase "Delete Transaction" as UC_DeleteTx
  usecase "Filter Transactions" as UC_FilterTx

  usecase "Add Budget (Category/Month)" as UC_AddBudget
  usecase "Edit Budget Cap" as UC_EditBudget
  usecase "Delete Budget" as UC_DeleteBudget
  usecase "Set Monthly Budget Cap" as UC_SetMonthlyCap

  usecase "Create Savings Goal" as UC_CreateGoal
  usecase "Edit Savings Goal" as UC_EditGoal
  usecase "Delete Savings Goal" as UC_DeleteGoal
  usecase "Add Goal Contribution" as UC_AddContrib
  usecase "View Goal Contributions" as UC_ViewContrib

  usecase "Create Note" as UC_CreateNote
  usecase "View Notes" as UC_ViewNotes
  usecase "Delete Note" as UC_DeleteNote
}

user --> UC_Register
user --> UC_Login
user --> UC_Exit

user --> UC_Dashboard
user --> UC_SetIncome
UC_SetIncome ..> UC_AutoApply : <<include>>
UC_Login ..> UC_AutoApply : <<include>>

user --> UC_AddTx
user --> UC_EditTx
user --> UC_DeleteTx
user --> UC_FilterTx

user --> UC_AddBudget
user --> UC_EditBudget
user --> UC_DeleteBudget
user --> UC_SetMonthlyCap

user --> UC_CreateGoal
user --> UC_EditGoal
user --> UC_DeleteGoal
user --> UC_AddContrib
user --> UC_ViewContrib

user --> UC_CreateNote
user --> UC_ViewNotes
user --> UC_DeleteNote

@enduml

