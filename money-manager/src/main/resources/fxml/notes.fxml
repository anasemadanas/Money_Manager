<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.moneymanager.ui.controller.NoteController"
      maxHeight="Infinity" maxWidth="Infinity">


    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
        <Button text="+ New Note"  onAction="#handleAdd"    styleClass="btn-primary"/>
        <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="noteCountLabel" styleClass="summary-text"/>
    </HBox>

    <Separator/>


    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.32">


        <VBox styleClass="notes-list-panel" minWidth="180">
            <ListView fx:id="noteListView" VBox.vgrow="ALWAYS" styleClass="note-list-view"/>
        </VBox>


        <VBox styleClass="note-detail-pane" spacing="6" minWidth="300">
            <padding><Insets top="20" right="20" bottom="16" left="20"/></padding>

            <Label fx:id="detailPlaceholder"
                   text="Select a note to read it, or click '+ New Note' to create one."
                   styleClass="no-data-label" wrapText="true"/>

            <VBox fx:id="detailContent" visible="false" managed="false"
                  spacing="6" VBox.vgrow="ALWAYS">
                <Label fx:id="noteTitleLabel"   styleClass="note-detail-title" wrapText="true"/>
                <Label fx:id="noteCreatedLabel" styleClass="note-detail-meta"/>
                <Separator/>
                <TextArea fx:id="noteContentArea" VBox.vgrow="ALWAYS"
                          editable="false" wrapText="true" styleClass="note-content-area"/>
            </VBox>

        </VBox>

    </SplitPane>

</VBox>
