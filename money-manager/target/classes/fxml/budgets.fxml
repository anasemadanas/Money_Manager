<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.moneymanager.ui.controller.BudgetController"
      maxHeight="Infinity" maxWidth="Infinity">

    <!-- Action + period toolbar -->
    <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
        <Button text="+ Add Budget" onAction="#handleAdd"    styleClass="btn-primary"/>
        <Button fx:id="editButton"   text="Edit Cap" onAction="#handleEdit"   styleClass="btn-secondary"/>
        <Button fx:id="deleteButton" text="Delete"   onAction="#handleDelete" styleClass="btn-danger"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Month:" styleClass="filter-label"/>
        <ComboBox fx:id="monthCombo" prefWidth="130"/>
        <Label text="Year:"  styleClass="filter-label"/>
        <ComboBox fx:id="yearCombo"  prefWidth="90"/>
    </HBox>

    <Separator/>

    <!-- Monthly Balance Card -->
    <VBox styleClass="monthly-balance-section" spacing="8">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Monthly Budget" styleClass="section-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="setBalanceButton" text="Set Monthly Budget"
                    onAction="#handleSetBalance" styleClass="btn-secondary"/>
        </HBox>

        <!-- Shown when no balance is set -->
        <Label fx:id="balancePlaceholderLabel"
               text="No monthly budget set. Click 'Set Monthly Budget' to set a total spending limit for this month."
               styleClass="budget-amount" wrapText="true"/>

        <!-- Shown when balance is set -->
        <VBox fx:id="balanceProgressPane" visible="false" managed="false" spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="balanceSpentLabel" styleClass="budget-amount"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="balanceRemainingLabel" styleClass="pct-green"/>
            </HBox>
            <ProgressBar fx:id="monthlyBalanceBar" maxWidth="Infinity" prefHeight="14"/>
        </VBox>
    </VBox>

    <Separator/>

    <!-- Category budget rows -->
    <Label text="Category Budgets" styleClass="section-label">
        <padding><Insets top="8" right="16" bottom="2" left="16"/></padding>
    </Label>
    <ListView fx:id="budgetListView" VBox.vgrow="ALWAYS" styleClass="budget-list-view"/>

    <!-- Summary footer -->
    <HBox styleClass="summary-bar" alignment="CENTER_LEFT">
        <padding><Insets top="7" right="16" bottom="7" left="16"/></padding>
        <Label fx:id="summaryLabel" styleClass="summary-text" text=""/>
    </HBox>

</VBox>
