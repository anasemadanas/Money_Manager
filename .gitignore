# =========================================================================
# Money Manager - Root .gitignore
# =========================================================================

# Java & Maven
target/
**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.next
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml
dependency-reduced-pom.xml.tmp
**/dependency-reduced-pom.xml
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Compilation Artifacts & Class files
*.class
*.log
*.err
err.txt
**/err.txt
output/
**/output/
build/
**/build/
!**/src/main/**/build/
!**/src/test/**/build/

# Local databases & logs
*.db
*.sqlite
money-manager.db
**/money-manager.db

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
**/out/

# VS Code
.vscode/

# STS / Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Operating System Files
Thumbs.db
desktop.ini
.DS_Store

# Local properties / secrets
local.properties
.env
*.local
